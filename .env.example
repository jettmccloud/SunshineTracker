# PostgreSQL connection string (Replit provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/sunshinetracker

# CourtListener API token (optional but recommended for higher rate limits)
# Get one at: https://www.courtlistener.com/help/api/rest/
COURTLISTENER_API_TOKEN=

# JWT secret for auth tokens
JWT_SECRET=change-this-to-a-random-string
